{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.38/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 0,
  "default_container_padding": 8,
  "border": true,
  "border_width": 8,
  "border_offset": -1,
  "transparency": true,
  "transparency_alpha": 240,
  "resize_delta": 80,
  "mouse_follows_focus": false,
  "theme": {
    "palette": "Base16",
    "name": "TokyoCityDark",
    "unfocused_border": "Base03",
    "bar_accent": "Base0D"
  },
  "animation": {
    "enabled": true,
    "duration": 200,
    "fps": 120,
    "style": "EaseOutSine"
  },
  "bar_configurations": [
    "$Env:KOMOREBI_CONFIG_HOME/bar/komorebi.bar.monitor0.json",
    "$Env:KOMOREBI_CONFIG_HOME/bar/komorebi.bar.monitor1.json"
  ],
  "monitors": [
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "HorizontalStack"
        },
        {
          "name": "2",
          "layout": "VerticalStack"
        },
        {
          "name": "3",
          "layout": "Grid"
        },
        {
          "name": "4",
          "layout": "VerticalStack"
        },
        {
          "name": "5",
          "layout": "Grid"
        },
        {
          "name": "6",
          "layout": "Grid"
        },
        {
          "name": "7",
          "layout": "Grid"
        },
        {
          "name": "8",
          "layout": "VerticalStack"
        },
        {
          "name": "9",
          "layout": "VerticalStack"
        }
      ]
    }
  ]
}
